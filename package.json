{
  "name": "trainforge-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "opennextjs-cloudflare build && bash scripts/prepare-pages-deploy.sh",
    "build:pages": "npm run build",
    "build:next": "next build",
    "dev": "next dev --port 2021",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check:bundle": "node scripts/check-bundle-budget.mjs",
    "preview": "opennextjs-cloudflare build && bash scripts/prepare-pages-deploy.sh && wrangler pages dev .open-next",
    "deploy": "opennextjs-cloudflare build && bash scripts/prepare-pages-deploy.sh && wrangler pages deploy .open-next --project-name=trainforge --branch=main --commit-dirty=true",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@serwist/next": "^9.5.11",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-virtual": "^3.14.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.21.0",
    "next": "15.5.19",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.79.0",
    "recharts": "^3.8.1",
    "serwist": "^9.5.11",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260619.1",
    "@eslint/eslintrc": "^3",
    "@opennextjs/cloudflare": "^1.19.11",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "axe-core": "^4.12.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.19",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "prettier": "^3.8.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9",
    "vitest-axe": "^0.1.0",
    "wrangler": "^4.103.0"
  }
}